{
  "name": "@predict9ja/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "txline:probe": "tsx src/probe.ts",
    "txline:sync-fixtures": "tsx src/sync-command.ts",
    "txline:probe-scores": "tsx src/probe-scores.ts",
    "txline:import-history": "tsx src/import-history.ts",
    "txline:stream-scores": "tsx src/stream-scores.ts",
    "txline:fetch-proof": "tsx src/fetch-proof.ts",
    "txline:verify-proof": "tsx src/verify-proof.ts",
    "txline:verify-latest-score": "tsx src/verify-latest-score.ts",
    "txline:diagnose-proof": "tsx src/diagnose-proof.ts",
    "txline:retry-verification": "tsx src/retry-verification.ts",
    "txline:ingest-score-snapshot": "tsx src/ingest-score-snapshot.ts",
    "txline:validation-support-bundle": "tsx src/validation-support-bundle.ts",
    "txline:replay-scores": "tsx src/replay-scores.ts",
    "markets:generate": "tsx src/markets-generate.ts",
    "markets:resolve": "tsx src/markets-resolve.ts",
    "markets:settle": "tsx src/markets-settle.ts",
    "demo:reset": "tsx src/demo-reset.ts",
    "demo:run": "tsx src/demo-run.ts"
  },
  "dependencies": {
    "@predict9ja/domain": "workspace:*",
    "zod": "^3.25.67",
    "@predict9ja/db": "workspace:*",
    "@predict9ja/txline": "workspace:*",
    "@predict9ja/verification": "workspace:*",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@predict9ja/config": "workspace:*",
    "@types/node": "^22.15.32",
    "eslint": "^9.29.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
