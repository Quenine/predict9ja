DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_TEST_URL="postgresql://USER:PASSWORD@HOST:5432/TEST_DATABASE?schema=public"
DEMO_SESSION_SECRET="replace-with-a-random-secret-at-least-16-characters"
POSTGRES_PORT="5432"
TXLINE_NETWORK="devnet"
TXLINE_API_TOKEN="replace-with-activated-txline-api-token"
TXLINE_REQUEST_TIMEOUT_MS="30000"
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_COMMITMENT="confirmed"
SOLANA_VALIDATION_TIMEOUT_MS="15000"

